class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        int windowSum = 0;

        for(int i = 0;i<k;i++){
            windowSum += nums[i];
        }

        double maxAvg = windowSum/k;

        for(int right = k;right < nums.size();right++){
            windowSum += nums[right];
            windowSum -= nums[right-k];

            maxAvg = max(maxAvg,windowSum/k);
        }
        return maxAvg;
    }
};
