class Solution {
public:
    int numOfSubarrays(vector<int>& arr, int k, int threshold) {
        double windowSum = 0;
        long long subarr = 0;
        for(int i = 0;i<k ; i++){
            windowSum += arr[i];
        }
        if (windowSum / k >= threshold) subarr++; 

        for(int right = k;right < arr.size();right++){
            windowSum += arr[right];
            windowSum -= arr[right-k];

            if(windowSum/k >= threshold){
                subarr++;
            }
        }
        return subarr;
    }
};
