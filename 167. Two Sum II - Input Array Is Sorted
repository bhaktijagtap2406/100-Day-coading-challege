class Solution {
public:
    vector<int> twoSum(vector<int>& arr, int target) {
        int left = 1,right = arr.size();
        int sum = 0;

        while(left<right){
            sum = arr[left-1]+arr[right-1];

            if(sum == target) return{left,right};
            else if(sum<target){
                left++;
            }
            else{
                right--;
            }
        }
        return {};
    }
};
